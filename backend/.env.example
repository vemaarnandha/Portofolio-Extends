# Supabase (dapatkan dari project dashboard Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (untuk storage operations - dapatkan dari Supabase Dashboard > Project Settings > API > service_role key)
# JANGAN pernah expose key ini ke client/frontend
SUPABASE_SERVICE_ROLE=your-service-role-key

# JWT Secret (generate random string minimal 32 karakter)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# CORS - domain frontend Vercel Anda
CORS_ORIGIN=https://your-vercel-domain.vercel.app
